#include <stdio.h>

int main() {
    double base, result = 1.0;
    int exp, i;

    // Get input from user
    printf("Enter base: ");
    scanf("%lf", &base);
    printf("Enter exponent (integer): ");
    scanf("%d", &exp);

    // Calculate power
    if (exp >= 0) {
        for (i = 1; i <= exp; ++i) {
            result *= base;
        }
    } else {
        for (i = 1; i <= -exp; ++i) {
            result /= base;
        }
    }

    printf("%.2lf ^ %d = %.2lf\n", base, exp, result);

    return 0;
}
