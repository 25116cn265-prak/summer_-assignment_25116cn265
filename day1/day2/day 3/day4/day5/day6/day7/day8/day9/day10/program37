#include <stdio.h>

int main() {
    int rows = 5;

    // Outer loop for each row
    for (int i = 1; i <= rows; i++) {
        
        // Inner loop to print spaces
        for (int j = 1; j <= rows - i; j++) {
            printf(" ");
        }
        
        // Inner loop to print stars
        for (int k = 1; k <= (2 * i - 1); k++) {
            printf("*");
        }
        
        // Move to the next line
        printf("\n");
    }
    return 0;
}
