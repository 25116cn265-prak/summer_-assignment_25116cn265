#include <stdio.h>

int main() {
    int rows = 5; // Total number of rows in the pattern
    
    // Outer loop for the rows
    for (int i = 1; i <= rows; i++) {
        // Inner loop to print the number 'i' exactly 'i' times
        for (int j = 1; j <= i; j++) {
            printf("%d", i);
        }
        // Move to the next line after each row finishes
        printf("\n");
    }
    
    return 0;
}
