#include <stdio.h>

int main() {
    int rows = 5;

    for (int i = 1; i <= rows; i++) {
        // 1. Print leading spaces
        for (int space = 1; space <= rows - i; space++) {
            printf(" ");
        }

        // 2. Print characters in ascending order
        for (int j = 0; j < i; j++) {
            printf("%c", 'A' + j);
        }

        // 3. Print characters in descending order
        for (int j = i - 2; j >= 0; j--) {
            printf("%c", 'A' + j);
        }

        // Move to the next line
        printf("\n");
    }

    return 0;
}
