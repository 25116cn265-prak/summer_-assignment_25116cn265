#include <stdio.h>

int main() {
    int rows = 5;

    // Outer loop controls the rows
    for (int i = rows; i >= 1; i--) {
        // Inner loop handles columns to print stars
        for (int j = 1; j <= i; j++) {
            printf("*");
        }
        // Advance to a new line
        printf("\n");
    }
    return 0;
}
