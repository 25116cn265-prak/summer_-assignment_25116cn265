#include <stdio.h>

int main() {
    int rows = 5;

    // Outer loop for rows
    for (int i = 1; i <= rows; i++) {
        
        // Inner loop for printing spaces
        for (int j = 1; j < i; j++) {
            printf(" ");
        }
        
        // Inner loop for printing stars
        for (int k = 1; k <= (rows * 2 - (2 * i - 1)); k++) {
            printf("*");
        }
        
        // Move to the next line
        printf("\n");
    }
    return 0;
}
