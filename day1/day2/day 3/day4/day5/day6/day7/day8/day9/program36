#include <stdio.h>

int main() {
    int size = 5;

    // Loop through each row
    for (int i = 1; i <= size; i++) {
        // Loop through each column
        for (int j = 1; j <= size; j++) {
            // Print asterisk if it is a boundary position
            if (i == 1 || i == size || j == 1 || j == size) {
                printf("*");
            } else {
                printf(" ");
            }
        }
        // Move to the next line after completing a row
        printf("\n");
    }
    return 0;
}
