#include <stdio.h>

int main() {
    int num, digit;
    long product = 1;

    printf("Enter a number: ");
    scanf("%d", &num);

    // Handle negative numbers
    if (num < 0) {
        num = -num;
    }

    // Extract and multiply digits
    while (num > 0) {
        digit = num % 10;
        product *= digit;
        num = num / 10;
    }

    printf("Product of digits = %ld\n", product);
    return 0;
}