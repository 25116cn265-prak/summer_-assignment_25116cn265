#include <stdio.h>
#include <stdlib.h> // Required for abs()

int main() {
    int num, remainder;
    int sum = 0;
    
    printf("Enter a number: ");
    scanf("%d", &num);
    
    // Convert to absolute value to safely handle negative numbers
    num = abs(num);
    
    while (num != 0) {
        remainder = num % 10; // Get the last digit
        sum += remainder;     // Add it to the total sum
        num /= 10;            // Remove the last digit
    }
    
    printf("Sum of the individual digits: %d\n", sum);
    return 0;
}